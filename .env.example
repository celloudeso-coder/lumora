# Copier en .env.local puis remplir avec les valeurs de `supabase status`.
# En local, `supabase start` affiche l'URL API et les clés anon/service_role.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54351
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service role : SERVEUR UNIQUEMENT (Server Actions) — jamais côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=
